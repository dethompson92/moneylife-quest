{
  "name": "moneylife-quest",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@11.5.0",
  "type": "module",
  "scripts": {
    "predev": "node scripts/parseContext.js",
    "dev": "vite",
    "lint:privacy": "node scripts/privacyLint.mjs",
    "lint:content": "node scripts/contentLint.mjs",
    "lint:quota": "node scripts/quotaLint.mjs",
    "lint:achievements": "node scripts/achievementLint.mjs",
    "lint:goals": "node scripts/goalLint.mjs",
    "lint:all": "node scripts/privacyLint.mjs && node scripts/contentLint.mjs && node scripts/quotaLint.mjs && node scripts/achievementLint.mjs && node scripts/goalLint.mjs",
    "prebuild": "node scripts/parseContext.js && node scripts/privacyLint.mjs && node scripts/contentLint.mjs && node scripts/quotaLint.mjs && node scripts/achievementLint.mjs && node scripts/goalLint.mjs",
    "build": "tsc --noEmit -p tsconfig.app.json && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "pretest": "node scripts/parseContext.js",
    "test": "vitest run",
    "test:run": "vitest run",
    "test:e2e": "VITE_BASE_PATH=/ pnpm run build && playwright test"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^5.4.21"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^18.3.16",
    "@types/react-dom": "^18.3.5",
    "jsdom": "^25.0.1",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
